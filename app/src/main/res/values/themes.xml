<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HalalFinder" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Use the launcher icon as a fallback if the custom splash isn't in a drawable folder -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="postSplashScreenTheme">@style/Theme.HalalFinder</item>
    </style>
</resources>